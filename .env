# Local development settings
# Option A (no Supabase): run in demo mode
VITE_DEMO_MODE=true

# Only these emails can log in / be promoted as admin (comma-separated)
VITE_ADMIN_EMAIL_ALLOWLIST=admin@college.edu

# Option B (real Supabase auth): disable demo mode and set these
# VITE_DEMO_MODE=false
# VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
# VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Optional: admin signup code (only required when signing up as admin)
VITE_ADMIN_SIGNUP_CODE=ad1290

# Required (if you want role-based signup/login codes)
# Students must enter this code during signup + login when selecting Student
VITE_STUDENT_SIGNUP_CODE=st1290

# Staff must enter this code during signup + login when selecting Staff
VITE_STAFF_SIGNUP_CODE=sf1290
